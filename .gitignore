# Aegis Triage OS - Global GitIgnore rules

# Node / Frontend / Next.js
node_modules/
.next/
out/
build/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
debug-storybook.log

# Storybook Cache & Outputs
.storybook-status
storybook-static/

# Environment Variables & Secrets (CRITICAL Security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Keep example environments tracked
!.env.example

# Python / Backend Compiled Files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python Virtual Environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Testing & Coverage Outputs
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/
.cache/

# LangGraph / Checkpoint SQLite DBs
*.db
!storage/langgraph_checkpoints.db.template
storage/*.db

# OS / Temporary Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
