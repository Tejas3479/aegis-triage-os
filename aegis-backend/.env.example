# Aegis Triage OS - Environment Configuration Example
# Copy this to .env and fill in the actual secrets

# 1. API Configurations
PROJECT_NAME="Aegis Triage OS"
ENVIRONMENT="production"
SECRET_KEY="REPLACE_WITH_SECURE_RANDOM_UUID"

# 2. Database Matrix (Supabase)
# Find these in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-service-role-key-here"

# 3. AI Inference Matrix (Google GenAI)
# Find this in Google AI Studio
GOOGLE_GENAI_API_KEY="your-google-genai-api-key-here"
GEMINI_API_KEY="your-google-genai-api-key-here"

# 4. Security & Networking
# Use comma-separated list of domains for production (e.g., "https://aegis-frontend.vercel.app")
ALLOWED_ORIGINS="*"
