# Aegis Triage OS - Environment Configuration Example
# Copy to .env and fill in secrets (never commit .env)

PROJECT_NAME="Aegis Triage OS"
ENVIRONMENT="development"
SECRET_KEY="REPLACE_WITH_SECURE_RANDOM_UUID"

# Supabase (Project Settings -> API)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-service-role-key-here"

# Google GenAI (clinical reasoning only when STT_PROVIDER=local)
GOOGLE_GENAI_API_KEY="your-google-genai-api-key-here"

# CORS (comma-separated; no wildcard in production)
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Clinical staff auth (no hardcoded passwords in source)
HOSPITAL_PROVISIONING_CODE="AEGIS-DEV-ONLY"
BOOTSTRAP_ADMIN_PASSWORD="change-me-admin"
BOOTSTRAP_DOCTOR_PASSWORD="change-me-doctor"

# Speech-to-text: local (default, PHI-safe) | cloud (explicit opt-in)
STT_PROVIDER="local"
VOSK_MODEL_PATH="models/vosk-en-small"

# LangGraph checkpoints: SQLite file (default) or Postgres URL
CHECKPOINT_SQLITE_PATH="storage/langgraph_checkpoints.db"
# CHECKPOINT_DATABASE_URL="postgresql://user:pass@host:5432/aegis"
